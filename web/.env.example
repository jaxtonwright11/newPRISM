# PRISM — Environment Variables
# Copy this to .env.local and fill in your values

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Mapbox (required for live map)
NEXT_PUBLIC_MAPBOX_TOKEN=

# Site URL (canonical)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Anthropic / Claude API (optional — powers AI suggestions in admin panel)
ANTHROPIC_API_KEY=

# VAPID keys for Web Push (optional — generate with web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# PostHog (optional — analytics)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Cron job secret (Vercel sends this as Authorization header)
CRON_SECRET=

# Sentry (optional — error monitoring)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# Resend (optional — email digest)
RESEND_API_KEY=

# n8n webhooks (optional — automation integration)
N8N_WEBHOOK_SECRET=

# Admin access (either works — email is easiest, IDs are more secure)
ADMIN_EMAILS=
ADMIN_USER_IDS=

# API rate limiting (optional — defaults to 120 requests per window)
# API_RATE_LIMIT_MAX=120
